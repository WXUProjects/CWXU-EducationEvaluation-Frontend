			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "教学评价系统"
			}
		},
		{
			"path": "pages/home/home",
			"style": {
				"navigationBarTitleText": "教学评价系统"
			}
		},
		{
			"path": "pages/evaluate/evaluate",
			"style": {
				"navigationBarTitleText": "教学评价系统"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "教学评价系统"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "教学评价系统",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {}
