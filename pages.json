{
	"easycom": {
	    "autoscan": true,
		    "custom": {
		      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		    }
	  },
	"pages": [//pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages  
